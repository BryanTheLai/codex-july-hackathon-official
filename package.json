{
  "name": "kaunter-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Multilingual aircon service desk MSME demo with governed SOP learning loop.",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "start": "tsx server/index.ts --production",
    "bootstrap:demo": "tsx server/bootstrap-demo.ts",
    "demo:seed": "tsx server/demo-seed-cli.ts",
    "demo:reset": "tsx server/demo-reset.ts",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "oxlint --deny-warnings src server tests e2e",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify": "npm run lint && npm run test && npm run typecheck && npm run build && npm run test:e2e"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BryanTheLai/codex-july-hackathon-official.git"
  },
  "keywords": [
    "msme",
    "aircon",
    "evaluation",
    "synthetic-demo"
  ],
  "author": "KaunterAI",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/BryanTheLai/codex-july-hackathon-official/issues"
  },
  "homepage": "https://github.com/BryanTheLai/codex-july-hackathon-official#readme",
  "engines": {
    "node": ">=22.12"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/view": "^6.43.6",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/instrument-sans": "^5.2.8",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@supabase/supabase-js": "^2.110.3",
    "@tanstack/react-table": "^8.21.3",
    "@uiw/react-codemirror": "^4.25.11",
    "express": "^5.2.1",
    "ical-generator": "^11.0.0",
    "lucide-react": "^1.24.0",
    "openai": "^6.46.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0",
    "recharts": "^3.9.2",
    "tsx": "^4.23.1",
    "vite": "^8.1.4",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.73.0",
    "pg-mem": "^3.0.14",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}

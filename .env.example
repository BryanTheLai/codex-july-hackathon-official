# OpenAI-compatible text provider
# empty -> https://api.openai.com/v1
# LiteLLM Responses example -> http://127.0.0.1:4000
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-5.5
LLM_API_MODE=responses
JUDGE_MODEL=
LIVE_AGENT_ENABLED=false

# Voice delivery (inbound transcription currently uses OpenAI whisper-1)
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=coral

# Telegram + fixed Supabase workspace
# TELEGRAM_BOT_TOKEN -> @BotFather /token
# TELEGRAM_WEBHOOK_SECRET -> openssl rand -hex 32
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
LIVE_TELEGRAM_ENABLED=false
# Calendar invitations use the approved booking's own Telegram conversation.
CALENDAR_DISPATCH_ENABLED=true
CALENDAR_DEFAULT_DURATION_MINUTES=30
CALENDAR_LOCATION=
CALENDAR_UID_DOMAIN=calendar.kaunterai.test
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
KAUNTER_WORKSPACE_ID=demo

PORT=5173

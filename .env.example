# OpenAI-compatible text provider
# empty -> https://api.openai.com/v1
# LiteLLM Responses example -> http://127.0.0.1:4000
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-5.5
LLM_API_MODE=responses
JUDGE_MODEL=
LIVE_AGENT_ENABLED=false

# Voice providers. Both default to OpenAI; select ElevenLabs independently for direct STT or TTS.
SPEECH_PROVIDER=openai
TTS_PROVIDER=openai

# OpenAI voice fallback (uses the same LLM_* credentials above)
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=coral

# ElevenLabs direct voice (required only when its provider is selected)
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
ELEVENLABS_STT_MODEL=scribe_v2
ELEVENLABS_TTS_MODEL=eleven_v3
ELEVENLABS_VOICE_ID=
# Optional code-managed voice controls. Leave blank to keep the voice defaults.
ELEVENLABS_TTS_STABILITY=
ELEVENLABS_TTS_SIMILARITY_BOOST=
ELEVENLABS_TTS_STYLE=
ELEVENLABS_TTS_SPEED=
ELEVENLABS_TTS_USE_SPEAKER_BOOST=

# Telegram + fixed Supabase workspace
# TELEGRAM_BOT_TOKEN -> @BotFather /token
# TELEGRAM_WEBHOOK_SECRET -> openssl rand -hex 32
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
LIVE_TELEGRAM_ENABLED=false
# Calendar invitations use the approved booking's own Telegram conversation.
CALENDAR_DISPATCH_ENABLED=true
CALENDAR_DEFAULT_DURATION_MINUTES=30
CALENDAR_LOCATION=
CALENDAR_UID_DOMAIN=calendar.kaunterai.test
# Optional single-admin Google Calendar synchronization. With this disabled or
# unconnected, autonomous booking keeps using the deterministic demo schedule.
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ADMIN_TOKEN=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=
GOOGLE_CALENDAR_ID=primary
# Generate once with: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
GOOGLE_CALENDAR_TOKEN_ENCRYPTION_KEY=
GOOGLE_CALENDAR_TIME_ZONE=Asia/Kuala_Lumpur
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
KAUNTER_WORKSPACE_ID=demo

PORT=5173
